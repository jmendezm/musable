# Backend Configuration
NODE_ENV=production
PORT=3000
BACKEND_PORT=3001

# Frontend Configuration (Create React App - must use REACT_APP_ prefix)
REACT_APP_BASE_URL=http://127.0.0.1:3000
REACT_APP_API_BASE_URL=http://127.0.0.1:3001/api
REACT_APP_WEBSOCKET_URL=ws://127.0.0.1:3001

# Database
DATABASE_PATH=./musable.db

# JWT & Session Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-super-secret-session-key

# Supported Formats
SUPPORTED_FORMATS=["mp3","flac","wav","m4a","aac","ogg"]

# Admin Credentials
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10000

# CORS
CORS_ORIGIN=http://127.0.0.1:3000

# Logging
LOG_LEVEL=info
